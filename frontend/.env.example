VITE_CONTRACT_ADDRESS=

# Production (Vercel, etc.): backend URL with no trailing slash. REQUIRED when frontend is deployed.
# Example: https://your-backend.vercel.app  (add in Vercel → Project → Environment Variables, then redeploy)
# Leave unset for local dev (Vite proxy to backend).
# VITE_API_URL=https://your-backend.vercel.app

# Base URL for QR codes (MUST be HTTPS for iPhone scan). Use ngrok or your domain for phone demo.
# Example: https://abcd1234.ngrok.io or https://yourdomain.com
# Leave empty to use current page origin (same machine only).
# VITE_VERIFY_BASE_URL=https://yourdomain.com

# In development: set to "false" or "0" to disable auto-login with demo account on the login page.
# VITE_AUTO_LOGIN=false
