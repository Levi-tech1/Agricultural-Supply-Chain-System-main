{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [{ "source": "/((?!api).*)", "destination": "/index.html" }],
  "functions": {
    "api/[...path].mjs": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "backend/**"
    }
  }
}
